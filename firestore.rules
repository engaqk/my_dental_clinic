rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is staff logged in?
    function isStaff() {
      return request.auth != null;
    }

    // --- APPOINTMENTS RULES ---
    match /appointments/{appointmentId} {
      // Patients can read to see their own booking or check slots
      // Staff can read all
      allow read: if true; 
      
      // Anyone can book an appointment
      allow create: if true;
      
      // Only staff can update status or delete
      allow update, delete: if isStaff();
    }

    // --- SETTINGS RULES ---
    match /settings/clinic {
      allow read: if true;      // Let patients see clinic name/branding/colors
      allow write: if isStaff();
    }
    
    match /settings/gateway {
      allow read, write: if isStaff(); // SECURE: Only staff can see SMS API keys
    }

    // --- MARKETING & BROADCAST RULES ---
    match /marketing_contacts/{id} {
      allow read, write: if isStaff();
    }
    
    match /broadcast_history/{id} {
      allow read, write: if isStaff();
    }

    // --- FALLBACK ---
    match /{document=**} {
      allow read, write: if isStaff();
    }
  }
}
