rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Is staff logged in?
    function isStaff() {
      return request.auth != null;
    }

    // --- APPOINTMENTS RULES ---
    match /appointments/{appointmentId} {
      allow read: if true;      // Public and staff both can read (for slot checking)
      allow create: if true;    // Public booking
      allow update, delete: if isStaff(); // Only staff can modify/delete
    }

    // --- SETTINGS RULES ---
    match /settings/clinic {
      allow read: if true;      // Let users see clinic name/branding
      allow write: if isStaff();
    }
    
    match /settings/gateway {
      allow read, write: if isStaff(); // SECURE: Only staff can see SMS API keys
    }

    // --- MARKETING & BROADCAST RULES ---
    match /marketing_contacts/{id} {
      allow read, write: if isStaff();
    }
    
    match /broadcast_history/{id} {
      allow read, write: if isStaff();
    }

    // --- GENERAL BACKFALL ---
    match /{document=**} {
      allow read, write: if isStaff();
    }
  }
}
