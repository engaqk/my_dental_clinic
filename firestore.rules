rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Appointments: Anyone can read/book, only staff can manage
    match /appointments/{appointmentId} {
      allow read, create, update: if true; 
      allow delete: if request.auth != null;
    }

    // Settings: Public can read, only staff can update (temporary open write for 'clinic' doc for setup)
    match /settings/{docId} {
      allow read: if true;
      allow write: if docId == 'clinic' || request.auth != null;
    }

    // Marketing Contacts & Broadcasts: Staff Only
    match /marketing_contacts/{contactId} {
      allow read, write: if request.auth != null;
    }
    
    match /sms_broadcasts/{historyId} {
      allow read, write: if request.auth != null;
    }

    // Default: Deny everything else
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
